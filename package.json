{
  "name": "opencode-preemptive-compaction",
  "version": "0.1.0",
  "description": "Standalone OpenCode plugin that proactively compacts sessions before hitting context limits. Extracted from oh-my-openagent.",
  "license": "SUL-1.0",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hook": "./src/preemptive-compaction.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build src/index.ts --outfile dist/preemptive-compaction.plugin.js --target bun"
  },
  "keywords": [
    "opencode",
    "plugin",
    "compaction",
    "context-window",
    "hook"
  ],
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/bun": "^1.3.14",
    "typescript": "^5.6.0"
  }
}
